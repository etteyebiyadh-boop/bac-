{
  "name": "bac-language-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && node prisma/seed-creative-content.js && node prisma/seed-ultimate-rich.js && node prisma/seed-comprehensive.js && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:content": "node prisma/seed-comprehensive.js",
    "prisma:seed:bac": "node prisma/seed-bac-official.js",
    "prisma:seed:sections": "node prisma/seed-sections.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.0.0",
    "openai": "^5.12.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}
